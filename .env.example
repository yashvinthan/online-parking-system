# Django Settings
DEBUG=1
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,parking.webistzu.online
DJANGO_CSRF_TRUSTED_ORIGINS=https://parking.webistzu.online,https://localhost:8000,http://localhost:8000,http://127.0.0.1:8000

# Database
DATABASE_URL=postgresql://parking_user:parking_password_123@db:5432/parking_system
POSTGRES_DB=parking_system
POSTGRES_USER=parking_user
POSTGRES_PASSWORD=parking_password_123

# Stripe Configuration (optional)
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_CURRENCY=inr

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Parking Configuration
BOOKING_HOURLY_RATE=50

# Email Verification
ACCOUNT_EMAIL_VERIFICATION=optional
